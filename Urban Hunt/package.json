{
  "name": "urban-hunt",
  "version": "0.2.0",
  "private": true,
  "description": "Hide & Seek urban hunt production architecture",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:server:dev\" \"npm:client:dev\"",
    "server:dev": "tsx watch --env-file-if-exists=.env server/src/index.ts",
    "client:dev": "vite --config client/vite.config.ts --host 0.0.0.0",
    "build": "tsc -p server/tsconfig.json --noEmit && vite build --config client/vite.config.ts",
    "start": "tsx --env-file-if-exists=.env server/src/index.ts",
    "check": "tsc -p server/tsconfig.json --noEmit && tsc -p client/tsconfig.json --noEmit",
    "migrate": "tsx --env-file-if-exists=.env scripts/migrate.ts",
    "seed:pois": "tsx --env-file-if-exists=.env scripts/seed-pois.ts",
    "import:pois": "tsx --env-file-if-exists=.env scripts/import-geojson.ts",
    "test": "vitest run",
    "test:smoke": "tsx test/socket-smoke.ts",
    "test:modes": "tsx test/modes-smoke.ts",
    "native:sync": "npm run build && cap sync",
    "native:android": "cap open android",
    "native:ios": "cap open ios"
  },
  "dependencies": {
    "@capacitor-community/background-geolocation": "^1.2.26",
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/geolocation": "*",
    "@capacitor/ios": "^8.4.0",
    "@capacitor/push-notifications": "^8.0.0",
    "@turf/turf": "^7.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "express": "^4.19.2",
    "firebase-admin": "^13.0.0",
    "leaflet": "^1.9.4",
    "multer": "^2.0.0",
    "pg": "^8.13.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "redis": "^4.7.0",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.8.3",
    "web-push": "^3.6.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/leaflet": "^1.9.15",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/web-push": "^3.6.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
