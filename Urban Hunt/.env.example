ADMIN_PIN=change-me
PORT=3000
REDIS_URL=redis://127.0.0.1:6379
DATABASE_URL=postgres://urban_hunt:urban_hunt@127.0.0.1:5432/urban_hunt
UPLOAD_DIR=data/uploads
DEMO_LOCATION_ENABLED=false
# Web Push (optional). If left blank the server auto-generates a keypair and
# persists it to data/vapid.json so subscriptions stay valid across restarts.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@urban-hunt.local
