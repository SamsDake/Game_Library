ADMIN_PIN=change-me
PORT=3000
REDIS_URL=redis://127.0.0.1:6379
DATABASE_URL=postgres://urban_hunt:urban_hunt@127.0.0.1:5432/urban_hunt
UPLOAD_DIR=data/uploads
DEMO_LOCATION_ENABLED=false
# Web Push (optional). If left blank the server auto-generates a keypair and
# persists it to data/vapid.json so subscriptions stay valid across restarts.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@urban-hunt.local
# Background location via the Traccar Client app (no extra server config needed).
# Players install Traccar Client and point it at this server's /api/traccar endpoint,
# using their in-app player identifier as the Traccar "Device identifier". Pings feed
# the normal location pipeline (cached and served to seekers with locationDelayMinutes
# delay), so tracking keeps working while the app is backgrounded or the phone is locked.
# Hand players the HTTPS URL (e.g. https://your-host/api/traccar) so the identifier isn't
# sent in clear text.
